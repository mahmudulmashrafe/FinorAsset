# ─── Supabase Configuration ───────────────────────────────────────────────────
# Copy this file to .env and fill in your own Supabase project values.
# Find these in: Supabase Dashboard → Settings → API

# ── Client-side (safe to expose — anon/publishable key only) ──────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Server-side (never expose to browser — no VITE_ prefix) ──────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ⚠️  service_role key: bypasses Row Level Security — keep secret!
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...
